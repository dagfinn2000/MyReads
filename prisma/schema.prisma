// MyReads data model.
//
// Design note: reading data (status, rating, review, dates) lives directly on
// Book rather than in a separate "reading entry" model. Every book row already
// belongs to exactly one user in this single-purpose app, so a join table
// would only add indirection.

generator client {
  provider = "prisma-client-js"
  // "native" covers local dev (Windows/macOS/Linux glibc); the musl target is
  // what the Alpine-based Docker image needs at runtime.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ReadingStatus {
  WANT_TO_READ
  READING
  READ
  DNF // did not finish
}

enum BookFormat {
  PHYSICAL
  EBOOK
  AUDIOBOOK
}

model User {
  id           String        @id @default(cuid())
  username     String        @unique
  passwordHash String // bcrypt
  createdAt    DateTime      @default(now())
  books        Book[]
  shelves      Shelf[]
  readingGoals ReadingGoal[]
}

/// A yearly reading goal ("24 books in 2026"). Progress is derived from
/// books with status READ finished in that year; hitting the target earns
/// a gold medal on the stats page.
model ReadingGoal {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  year      Int
  target    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, year])
}

/// A user-defined shelf ("Sanderson", "Fantasy") — freeform grouping
/// independent of reading status. Books can sit on many shelves at once;
/// deleting a shelf only removes the grouping, never the books.
model Shelf {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime @default(now())
  books     Book[]

  @@unique([userId, name])
}

model Book {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // --- bibliographic data ---
  title         String
  authors       String[]   @default([])
  isbn          String?
  description   String?
  /// Either a local cached path ("/api/covers/<id>.jpg") or a remote URL.
  coverUrl      String?
  pageCount     Int?
  /// Kept as a string because metadata APIs return partial dates ("1999", "2003-07").
  publishedDate String?
  tags          String[]   @default([])
  format        BookFormat @default(PHYSICAL)
  owned         Boolean    @default(true)
  /// Freeform series name (e.g. "Mistborn Era 1"); groups books together.
  seriesName    String?
  /// Position in the series. Float so novellas can slot in at 1.5.
  seriesNumber  Float?
  shelves       Shelf[]
  /// Open Library work ID (e.g. "OL45883W") when imported via search.
  openLibraryId String?

  // --- personal reading data ---
  status       ReadingStatus @default(WANT_TO_READ)
  /// 1–10 in half-star units: 7 = 3.5 stars. Null = unrated.
  rating       Int?
  review       String?
  dateStarted  DateTime?
  dateFinished DateTime?
  timesRead    Int           @default(0)
  /// Where you are in the book right now. Kept for READING and DNF
  /// ("stopped at p. 218"); cleared when the book is finished or reshelved.
  currentPage  Int?

  /// Denormalized lowercase "title + authors" so search can be a single
  /// case-insensitive `contains` (Prisma can't substring-search String[]).
  searchText String @default("")

  quotes   Quote[]
  reads    Read[]
  progress ProgressEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([userId, createdAt])
}

/// A *past* completed pass through a book. The Book row itself always holds
/// the latest read (status, dates, rating), so re-reading archives the
/// previous pass here. `timesRead` on Book is kept in sync as
/// `reads.count + (status == READ ? 1 : 0)` — see lib/actions/reads.ts.
model Read {
  id     String @id @default(cuid())
  bookId String
  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)

  /// Both dates optional: "I know I read this in 2019" is a valid entry,
  /// and so is a fully undated "read it before" placeholder.
  dateStarted  DateTime?
  dateFinished DateTime?
  /// What you rated it *that* time, 1–10 half-star units. Null = unrated;
  /// the Book row's rating stays your current overall rating.
  rating Int?

  createdAt DateTime @default(now())

  @@index([bookId, dateFinished])
}

/// A point-in-time reading position: "on this date I was at page N".
/// Logged automatically whenever `currentPage` changes, so the reading log
/// costs no extra effort. Powers the progress sparkline, pace/forecast, and
/// the reading-days heatmap. Pages-read-per-day is always the *delta between
/// consecutive entries* of a book — a lone first entry contributes nothing,
/// which is what makes anchors work: the upgrade migration seeds mid-read
/// books with their current position, and each new reading pass starts with
/// a page-0 anchor at the pass start (see logProgress in lib/actions/books.ts
/// and readAgain in lib/actions/reads.ts; the latest page-0 entry is the
/// pass boundary — see currentPassEntries in lib/progress.ts).
model ProgressEntry {
  id     String @id @default(cuid())
  bookId String
  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)

  page Int
  date DateTime @default(now())

  @@index([bookId, date])
}

/// A favourite quote or highlight from a book, with an optional page
/// reference and a personal note on why it stuck. Ownership is derived
/// through the book (books are per-user).
model Quote {
  id     String @id @default(cuid())
  bookId String
  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)

  text String
  page Int?
  note String?

  createdAt DateTime @default(now())

  @@index([bookId])
}

/// Caches raw Open Library / Google Books responses so repeated lookups of the
/// same query don't hit the external APIs. Rows are upserted per (source,
/// query) and considered stale after `expiresAt`.
model MetadataCache {
  id        String   @id @default(cuid())
  source    String // "ol-search" | "ol-work" | "gb-volume"
  query     String // normalized (lowercased, trimmed) lookup key
  payload   Json
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@unique([source, query])
}
