# ---------------------------------------------------------------------------
# MyReads environment configuration
# Copy to .env and fill in the values. Every variable used by the app is
# documented here; docker-compose.yml reads this file automatically.
# ---------------------------------------------------------------------------

# --- Postgres (used by the `db` service in docker-compose) ---
POSTGRES_USER=myreads
POSTGRES_PASSWORD=change-me-to-something-random
POSTGRES_DB=myreads

# --- App: database connection ---
# Only used when running the app or the prisma CLI OUTSIDE Docker (local
# dev). Inside Docker, docker-compose assembles DATABASE_URL from the
# POSTGRES_* values above, pointing at the `db` service.
DATABASE_URL=postgresql://myreads:change-me-to-something-random@localhost:5432/myreads

# --- Auth.js ---
# Secret used to sign/encrypt session JWTs. Generate with:
#   openssl rand -base64 32
AUTH_SECRET=generate-a-random-32-byte-base64-string

# Required when running behind a host Auth.js doesn't know about (i.e. any
# self-hosted deployment). Leave as true.
AUTH_TRUST_HOST=true

# --- Metadata fetching ---
# Optional. When set, Google Books is used to enrich Open Library results
# (descriptions and page counts are often better). The app works fully
# without it.
GOOGLE_BOOKS_API_KEY=

# --- Cover image cache ---
# Directory where imported cover images are stored. The Docker image sets
# this to /app/data/covers (backed by a named volume); for local dev the
# default ./data/covers is used if unset.
COVERS_DIR=

# --- Registration ---
# Set to "true" to disable new-account registration after you've created
# your own account (nice hardening for an internet-exposed instance).
DISABLE_REGISTRATION=false

# --- App port (docker-compose only) ---
# Host port the app is published on. Optional; defaults to 3000.
APP_PORT=3000
